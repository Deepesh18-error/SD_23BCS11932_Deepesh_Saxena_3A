        <mxCell id="dU_BJggv8GpyalvGTUkb-28" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Client should be able to see the video with zero or neglibile buffering." vertex="1">
