        <mxCell id="dU_BJggv8GpyalvGTUkb-16" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Functional Requirements" vertex="1">
          <mxGeometry height="30" width="154" x="77" y="234" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;ol&gt;&lt;li&gt;System should allow users to register, log in, and manage accounts.&lt;/li&gt;&lt;li&gt;System should support uploading large raw video files efficiently.&lt;/li&gt;&lt;li&gt;System should stream video smoothly using Adaptive Bitrate Streaming based on network conditions.&lt;/li&gt;&lt;li&gt;System should support real-time social interactions (likes, dislikes, comments).&lt;/li&gt;&lt;li&gt;System should allow users to search for videos by title or metadata.&lt;/li&gt;&lt;li&gt;System should generate a personalized home page feed based on watch history.&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="132" width="528" x="55" y="264" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-18" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Non-Functional Requirements" vertex="1">
          <mxGeometry height="30" width="181" x="77" y="418" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-22" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Support &lt;strong data-start=&quot;202&quot; data-end=&quot;240&quot;&gt;1 Billion Daily Active Users (DAU)&lt;/strong&gt;" vertex="1">
          <mxGeometry height="30" width="270" x="77.00000000000003" y="448" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-23" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="2. CAP Theorem: Availability &amp;gt;&amp;gt;&amp;gt;&amp;gt;&amp;gt; Consistency" vertex="1">
          <mxGeometry height="30" width="280" x="77" y="484" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-24" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="System availability &lt;strong data-start=&quot;751&quot; data-end=&quot;769&quot;&gt;≥ 99.9% uptime&lt;/strong&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="107" y="514" as="geometry" />
        </mxCell>
        <mxCell id="dU_BJggv8GpyalvGTUkb-25" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;3.Consistency&lt;/b&gt; in making &lt;b&gt;payments and in subscription plans&lt;/b&gt;" vertex="1">
